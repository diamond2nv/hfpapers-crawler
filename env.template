# hfpclawer configuration — .env template
# Copy to .env and edit

# HuggingFace Token (optional, increases API rate limit)
HF_TOKEN=

# DeepSeek API Key (for classification/analysis)
DEEPSEEK_API_KEY=

# Ollama local fallback (optional)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# LiteLLM Proxy (optional override)
LITELLM_PROXY=
LITELLM_API_KEY=

# HTTP proxy (optional, for arXiv download acceleration)
HTTP_PROXY=
HTTPS_PROXY=
