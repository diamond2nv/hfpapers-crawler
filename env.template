# HF Papers 配置系统 — .env 模板
# 复制为 .env 后编辑

# HuggingFace 令牌（可选，提升 API 频率）
HF_TOKEN=

# DeepSeek API（分类/分析用）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# Ollama 本地回退（可选）
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# LiteLLM Proxy（可选覆盖）
LITELLM_PROXY=
LITELLM_API_KEY=

# 代理（可选，用于 arXiv 下载加速）
HTTP_PROXY=
HTTPS_PROXY=
